NODE_ENV=development
PORT=4000

JWT_ACCESS_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

POSTGRES_URL=postgres://archer:jonpine@127.0.0.1:5432/mainframe
MONGODB_URI=mongodb://127.0.0.1:27017/mainframe

# On first local boot, set true to create/sync tables from Sequelize models.
DB_SYNC=true
# Keep false unless you intentionally want to drop/recreate tables.
DB_SYNC_FORCE=false
